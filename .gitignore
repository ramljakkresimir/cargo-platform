.claude/

# ── Logs ─────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ── OS ────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────────────
.vscode/
.idea/
