{
  "name": "cargo-platform",
  "version": "1.0.0",
  "private": true,

  "workspaces": [
    "backend",
    "frontend"
  ],

  "scripts": {
    "predev":   "node scripts/kill-ports.js",
    "dev":      "concurrently --kill-others-on-fail --names \"BACKEND,FRONTEND\" --prefix-colors \"blue.bold,green.bold\" \"npm run start:dev -w backend\" \"npm run dev -w frontend\"",
    "backend":  "npm run start:dev -w backend",
    "frontend": "npm run dev -w frontend",
    "build":    "npm run build -w backend && npm run build -w frontend",
    "seed:cities": "npm run seed:cities -w backend",
    "migration:create":   "npm run migration:create -w backend --",
    "migration:generate": "npm run migration:generate -w backend --",
    "migration:run":      "npm run migration:run -w backend",
    "migration:revert":   "npm run migration:revert -w backend",
    "migration:show":     "npm run migration:show -w backend"
  },

  "devDependencies": {
    "concurrently": "^9.0.0",
    "@nestjs/platform-express": "^11.0.1",
    "class-validator": "^0.15.1",
    "class-transformer": "^0.5.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  }
}
